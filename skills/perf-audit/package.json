{
  "name": "frontend-performance-agent",
  "version": "0.2.0",
  "description": "Autonomous AI agent that detects, audits, and optimizes Next.js performance — powered by Groq (free) or Anthropic Claude. Runs Lighthouse, analyzes bundles, and applies AST codemods automatically.",
  "type": "module",
  "main": "dist/agent.js",
  "exports": {
    ".": "./dist/agent.js",
    "./server": "./dist/server.js"
  },
  "bin": {
    "frontend-performance-agent": "./dist/agent-runner.js",
    "perf-agent": "./dist/agent-runner.js",
    "perf-audit": "./bin/perf-audit",
    "perf-agent-groq": "./bin/perf-agent-groq"
  },
  "files": [
    "dist",
    "bin",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/server.ts",
    "start": "node dist/server.js",
    "agent": "tsx src/agent-runner.ts",
    "agent:run": "node dist/agent-runner.js",
    "pipeline": "tsx src/pipeline-runner.ts",
    "prepublishOnly": "npm run build",
    "test": "vitest",
    "lint": "eslint src/**/*.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.36.0",
    "@babel/parser": "^7.23.0",
    "@babel/traverse": "^7.23.0",
    "@babel/types": "^7.23.0",
    "@modelcontextprotocol/sdk": "^0.5.0",
    "@next/bundle-analyzer": "^14.0.0",
    "chrome-launcher": "^1.0.0",
    "fs-extra": "^11.0.0",
    "glob": "^10.0.0",
    "groq-sdk": "^1.1.1",
    "jscodeshift": "^0.15.0",
    "lighthouse": "^11.0.0",
    "picocolors": "^1.0.0"
  },
  "peerDependencies": {
    "next": ">=13.0.0"
  },
  "peerDependenciesMeta": {
    "next": {
      "optional": false
    }
  },
  "devDependencies": {
    "@types/babel__traverse": "^7.20.0",
    "@types/fs-extra": "^11.0.0",
    "@types/jscodeshift": "^17.3.0",
    "@types/node": "^20.0.0",
    "eslint": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "mcp",
    "performance",
    "optimization",
    "next.js",
    "nextjs",
    "claude",
    "anthropic",
    "lighthouse",
    "core-web-vitals",
    "bundle-analyzer",
    "ai-agent",
    "frontend"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/frontend-performance-agent"
  },
  "author": "Prasad",
  "homepage": "https://github.com/your-org/frontend-performance-agent#readme"
}
